<Window x:Class="GFXRTool.CaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GFXR Capture"
        Width="400" Height="210"
        MinWidth="340"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="28"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{StaticResource AccentBrush}">
            <Grid Margin="14,0">
                <TextBlock Text="{Binding GameName}"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="White" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding StatusIndicatorText}"
                           Foreground="{Binding StatusIndicatorColor}"
                           FontSize="11" FontWeight="SemiBold"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── Content ────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="1" Margin="16,14,16,0">

            <Button Content="{Binding TriggerButtonText}"
                    Command="{Binding TriggerCaptureCommand}"
                    Style="{StaticResource PrimaryBtn}"
                    FontSize="14" FontWeight="SemiBold"
                    Padding="0,14"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,0,12"/>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Output: "
                           FontSize="11" Foreground="{StaticResource DimTextBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CaptureOutputDir}"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="300"
                           ToolTip="{Binding CaptureOutputDir}"
                           VerticalAlignment="Center"/>
            </StackPanel>

        </StackPanel>

        <!-- ── Status bar ─────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="{StaticResource AccentBrush}" Padding="10,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="White" FontSize="11"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</Window>
