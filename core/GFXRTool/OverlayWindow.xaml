<Window x:Class="GFXRTool.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="Width"
        Height="44">

    <Border Background="#D01A1A1A"
            BorderBrush="{Binding StatusIndicatorColor}"
            BorderThickness="1"
            CornerRadius="5"
            MouseLeftButtonDown="OnMouseDown"
            Cursor="SizeAll">
        <StackPanel Orientation="Vertical"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="12,6">
            <!-- Top row: GFXR label + status pill -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <TextBlock Text="GFXR"
                           Foreground="#707070"
                           FontSize="10" FontWeight="SemiBold"
                           FontFamily="Segoe UI"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBlock Text="{Binding StatusIndicatorText}"
                           Foreground="{Binding StatusIndicatorColor}"
                           FontSize="11" FontWeight="SemiBold"
                           FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <!-- Bottom row: key hint -->
            <TextBlock Text="{Binding TriggerKeyHint}"
                       Foreground="#505050"
                       FontSize="9"
                       FontFamily="Segoe UI"
                       HorizontalAlignment="Center"
                       Margin="0,2,0,0"/>
        </StackPanel>
    </Border>

</Window>
