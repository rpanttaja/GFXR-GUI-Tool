<Window x:Class="GFXRTool.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="Width"
        MinWidth="160"
        Height="68">

    <!-- Outer border — drag handle (mouse-down on the border itself moves the window) -->
    <Border x:Name="DragHandle"
            Background="#D01A1A1A"
            BorderBrush="{Binding StatusIndicatorColor}"
            BorderThickness="1"
            CornerRadius="6"
            MouseLeftButtonDown="OnDragHandleMouseDown"
            Cursor="SizeAll"
            Padding="12,8">
        <StackPanel>

            <!-- Top row: GFXR label + status text -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                <TextBlock Text="GFXR"
                           Foreground="#707070"
                           FontSize="10" FontWeight="SemiBold"
                           FontFamily="Segoe UI"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBlock Text="{Binding StatusIndicatorText}"
                           Foreground="{Binding StatusIndicatorColor}"
                           FontSize="11" FontWeight="SemiBold"
                           FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Trigger button — must stop mouse-down from bubbling to the drag handler -->
            <Button Content="{Binding TriggerButtonText}"
                    Command="{Binding TriggerCaptureCommand}"
                    FontSize="10" FontWeight="SemiBold"
                    FontFamily="Segoe UI"
                    Padding="10,4"
                    Cursor="Hand"
                    MouseLeftButtonDown="OnButtonMouseDown">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Foreground"      Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            CornerRadius="3"
                                            Padding="{TemplateBinding Padding}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#007ACC"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                                        <Setter Property="Background" Value="#8B1A1A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

        </StackPanel>
    </Border>

</Window>
