<Window x:Class="GFXRTool.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="172" Height="32">

    <Border Background="#D01A1A1A"
            BorderBrush="{Binding StatusIndicatorColor}"
            BorderThickness="1"
            CornerRadius="5"
            MouseLeftButtonDown="OnMouseDown"
            Cursor="SizeAll">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="12,0">
            <TextBlock Text="GFXR"
                       Foreground="#707070"
                       FontSize="10" FontWeight="SemiBold"
                       FontFamily="Segoe UI"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"/>
            <TextBlock Text="{Binding StatusIndicatorText}"
                       Foreground="{Binding StatusIndicatorColor}"
                       FontSize="11" FontWeight="SemiBold"
                       FontFamily="Segoe UI"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Border>

</Window>
