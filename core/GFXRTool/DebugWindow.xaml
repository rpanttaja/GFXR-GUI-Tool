<Window x:Class="GFXRTool.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Injection Diagnostics"
        Width="680" Height="440"
        Background="#1E1E1E"
        Foreground="#D4D4D4"
        WindowStartupLocation="Manual"
        Topmost="True">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="LogBox"
                 Grid.Row="0"
                 IsReadOnly="True"
                 Background="#0D0D0D"
                 Foreground="#D4D4D4"
                 CaretBrush="#D4D4D4"
                 FontFamily="Consolas"
                 FontSize="11"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 BorderThickness="1"
                 BorderBrush="#3C3C3C"
                 Padding="6"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Clear"
                    Padding="10,4" Margin="0,0,6,0"
                    Background="#2D2D2D" Foreground="#D4D4D4"
                    BorderBrush="#555" BorderThickness="1"
                    Click="Clear_Click"/>
            <Button Content="Copy All"
                    Padding="10,4"
                    Background="#007ACC" Foreground="White"
                    BorderThickness="0"
                    Click="CopyAll_Click"/>
        </StackPanel>
    </Grid>
</Window>
